# ============================================================
# futarive-admin 環境変数テンプレート
# ============================================================
# 使い方:
#   cp .env.example .env.local
#   各値を Supabase Dashboard / GCP Console から取得して埋める
# ============================================================

# --- Supabase ---
# Settings > API から取得（プロジェクトは my-app と同じ）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role Key（Supabase Dashboard > Settings > API > service_role）
# Webhook ハンドラー等で RLS をバイパスして読みたい場合に使う。
# クライアントには絶対露出させない。
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend（運用通知メール） ---
# https://resend.com/api-keys から発行
RESEND_API_KEY=

# 運営宛通知の送信先（課金異議申立て・新規予約通知など）
ADMIN_NOTIFY_EMAIL=

# --- Supabase Database Webhook 連携 ---
# Supabase Dashboard > Database > Webhooks で billing_events の UPDATE を
# /api/webhooks/billing-disputed に投げる際の Authorization シークレット。
# 任意の長い文字列をここと Supabase Webhook の HTTP Headers の両方に設定する。
SUPABASE_WEBHOOK_SECRET=

# --- GA4 Data API（Phase B 用・現時点では未使用） ---
# GA4 連携の詳細は docs/ga4-integration.md を参照
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_EMAIL=
GA4_SERVICE_ACCOUNT_PRIVATE_KEY=
